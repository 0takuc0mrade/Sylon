# BACKEND (.env in project root)

# Required API Keys
CEREBRAS_API_KEY=your_cerebras_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional API Keys
GOOGLE_PLACES_API_KEY=       

# Privy Auth (required for protected endpoints)
PRIVY_APP_SECRET=your_privy_app_secret_here

# Persistence
MORLEN_DB_PATH=data/morlen.db

# Tuning
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
GEMINI_MODEL=gemini-2.0-flash-exp
MORLEN_PERSONA_COUNT=2
MORLEN_DEBUG_MODE=False

# FRONTEND (frontend/.env.local)

# ElevenLabs Voice Agent (optional — orb still renders without it)
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id

# Privy Auth (required)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_CLIENT_ID=your_privy_client_id

# Backend URL override (default: http://localhost:8000)
# MORLEN_API_URL=http://localhost:8000
ALIBABA_RDS_URL="postgresql://user:password@rm-xxxxx.postgres.rds.aliyuncs.com:5432/morlen"
